{
    "name": "github-track-followers",
    "version": "2.2.0",
    "description": "🔨 CLI to display GitHub profile followers",
    "license": "MIT",
    "author": {
        "name": "Piotr Kowalski",
        "email": "piecioshka@gmail.com",
        "url": "https://piecioshka.pl"
    },
    "scripts": {
        "clear": "rm -rf reports/ coverage/",
        "clear:all": "rm -rf node_modules/ && npm run clear",
        "check-ts": "tsc --noEmit",
        "prebuild": "rm -rf dist/ types/",
        "build": "tsc",
        "test": "vitest run",
        "coverage": "vitest run --coverage"
    },
    "dependencies": {
        "colors": "^1.4.0",
        "debug": "^4.4.0",
        "minimist": "^1.2.8",
        "superagent": "^10.1.1"
    },
    "devDependencies": {
        "@types/debug": "^4.1.12",
        "@types/minimist": "^1.2.5",
        "@types/node": "^22.9.0",
        "@types/superagent": "^8.1.9",
        "@vitest/coverage-v8": "^2.1.5",
        "nock": "^13.5.6",
        "typescript": "^5.6.3",
        "vitest": "^2.1.5"
    },
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/piecioshka/github-track-followers.git"
    },
    "engines": {
        "node": ">=16"
    },
    "main": "index.js",
    "types": "types/index.d.ts",
    "files": [
        "bin",
        "dist",
        "types",
        "index.js",
        "package.json",
        "README.md",
        "LICENSE",
        "!**/*.spec.*"
    ],
    "keywords": [
        "cli",
        "github",
        "track",
        "followers",
        "listen",
        "util",
        "request",
        "api",
        "retrieve",
        "fetch",
        "get",
        "user",
        "gh",
        "git"
    ],
    "bin": {
        "github-track-followers": "bin/cli.js"
    }
}
